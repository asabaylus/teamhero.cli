# TeamHero Environment Schema
# Canonical credential store: ~/.config/teamhero/.env (created by `teamhero setup`)
# This schema documents all environment variables — actual values are never stored here.
# @defaultSensitive=false

# ─── Core Credentials ───────────────────────────────────────────────────────────

# GitHub access token (OAuth via `teamhero setup`, or fine-grained PAT: Contents, Metadata, Pull requests, Members read)
# @sensitive @required @type=string
GITHUB_PERSONAL_ACCESS_TOKEN=

# Authentication method used for GitHub (set automatically by `teamhero setup`)
# @type=enum(oauth,pat)
GITHUB_AUTH_METHOD=

# OpenAI API key (for AI-powered summaries and highlights)
# @sensitive @required @type=string(startsWith=sk-)
OPENAI_API_KEY=

# Asana personal access token
# @sensitive @type=string
ASANA_API_TOKEN=

# ─── AI Configuration ───────────────────────────────────────────────────────────

# Default AI model for all sections
# @type=string
AI_MODEL=gpt-5-mini

# Per-section model overrides (inherit from AI_MODEL if unset)
# @type=string
AI_TEAM_HIGHLIGHT_MODEL=
# @type=string
AI_MEMBER_HIGHLIGHTS_MODEL=
# @type=string
AI_INDIVIDUAL_SUMMARIES_MODEL=
# @type=string
AI_SUMMARIZER_MODEL=
# @type=string
VISIBLE_WINS_AI_MODEL=
# @type=string
AI_DISCREPANCY_ANALYSIS_MODEL=

# Custom OpenAI-compatible endpoint
# @sensitive @type=url
AI_API_BASE_URL=
# @sensitive @type=string
AI_API_KEY=

# OpenAI project ID
# @type=string
OPENAI_PROJECT=
# @type=string
AI_PROJECT=

# Flex processing
# @type=enum(flex,)
OPENAI_SERVICE_TIER=
# @type=number
OPENAI_FLEX_TIMEOUT=900000

# AI retry/timeout tuning
# @type=number
TEAMHERO_AI_MAX_RETRIES=2
# @type=number
TEAMHERO_AI_RETRY_DELAY_MS=500
# @type=number
TEAMHERO_AI_DISCREPANCY_TIMEOUT=120000

# ─── Visible Wins / Asana ───────────────────────────────────────────────────────

# Asana board configuration
# @type=string
ASANA_PROJECT_GID=
# @type=string
ASANA_SECTION_GID=
# @type=string
ASANA_SECTION_NAME=
# @type=string
ASANA_PRIORITY_FIELD=
# Path to multi-board YAML config
# @type=string
ASANA_BOARDS_CONFIG=

# Meeting notes
# @type=string
MEETING_NOTES_DIR=
# @type=enum(google-meet, local)
MEETING_NOTES_PROVIDER=google-meet

# Supplements file for visible wins
# @type=string
VISIBLE_WINS_SUPPLEMENTS_FILE=

# ─── Google Drive ────────────────────────────────────────────────────────────────

# Comma-separated Google Drive folder IDs for transcript retrieval
# @type=string
GOOGLE_DRIVE_FOLDER_IDS=
# @type=boolean @defaultSensitive=false
GOOGLE_DRIVE_INCLUDE_TRANSCRIPTS=true

# ─── Runtime Tuning ─────────────────────────────────────────────────────────────

# @type=enum(debug, info, warn, error)
TEAMHERO_LOG_LEVEL=
# @type=boolean @defaultSensitive=false
TEAMHERO_HEADLESS=
# @type=boolean @defaultSensitive=false
TEAMHERO_AI_DEBUG=
# @type=boolean @defaultSensitive=false
TEAMHERO_TEST_MODE=
# @type=boolean @defaultSensitive=false
TEAMHERO_ENABLE_PERIOD_DELTAS=
# @type=boolean @defaultSensitive=false
TEAMHERO_DISABLE_AI_AUDIT=
# @type=number
TEAMHERO_INDIVIDUAL_BATCH_SIZE=5
# @type=number
TEAMHERO_HISTORY_MAX_RUNS=20
# Path override for TUI binary
# @type=string
TEAMHERO_TUI_PATH=

# Override GitHub OAuth App client ID (development/testing only)
# @type=string
GITHUB_OAUTH_CLIENT_ID=
