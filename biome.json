{
	"$schema": "https://raw.githubusercontent.com/biomejs/biome/main/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!**/node_modules",
			"!**/.beads",
			"!**/.cursor",
			"!**/.claude",
			"!**/coverage",
			"!**/_bmad-output",
			"!**/_bmad",
			"!**/claude-plugin",
			"!**/.mcp.json",
			"!**/.claude-plugin",
			"!**/site",
			"!**/.cache"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"style": {
				"noNonNullAssertion": "off",
				"useImportType": "off"
			},
			"complexity": {
				"noForEach": "off"
			},
			"performance": {
				"noDelete": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noImplicitAnyLet": "off",
				"noControlCharactersInRegex": "off"
			}
		}
	},
	"formatter": {
		"formatWithErrors": true
	}
}
